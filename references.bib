@article{fletcherLinkChangingNews2024,
  title = {The Link between Changing News Use and Trust: Longitudinal Analysis of 46 Countries},
  shorttitle = {The Link between Changing News Use and Trust},
  author = {Fletcher, Richard and Andı, Simge and Badrinathan, Sumitra and Eddy, Kirsten A and Kalogeropoulos, Antonis and Mont'Alverne, Camila and Robertson, Craig T and Ross Arguedas, Amy and Schulz, Anne and Toff, Benjamin and Nielsen, Rasmus Kleis},
  date = {2024-11-22},
  journaltitle = {Journal of Communication},
  pages = {jqae044},
  issn = {0021-9916, 1460-2466},
  doi = {10.1093/joc/jqae044},
  url = {https://academic.oup.com/joc/advance-article/doi/10.1093/joc/jqae044/7907139},
  urldate = {2024-11-25},
  abstract = {Abstract             Changing levels of public trust in the news are of deep concern to both researchers and practitioners. We use data from 2015 to 2023 in 46 countries to explore how trust in news has changed, while also exploring the links with sociodemographic variables, differences by media system, and changing patterns of news use. We find that (a) there has been a small overall decline in trust in news since 2015, but also that (b) there are different trends in different countries. More specifically, trust has declined more in media environments that have become less structured by television news use, and increasingly structured by social media news use. Our findings underscore how changing structures of media use may be central to explaining trust dynamics in recent years, which suggests new avenues for restoring trust where it has eroded.},
  langid = {english},
  file = {/Users/clemensjarnach/03-UniofOxford/DPhil/06-Library/02-ArchiveLibrary/Fletcher-etal-2024.pdf}
}

