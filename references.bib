@article{daltonCognitiveMobilizationPartisan1984,
  title = {Cognitive Mobilization and Partisan Dealignment in Advanced Industrial Democracies},
  author = {Dalton, Russell J.},
  date = {1984},
  journaltitle = {The Journal of politics},
  volume = {46},
  number = {1},
  pages = {264--284},
  publisher = {Cambridge University Press},
  location = {New York, USA},
  issn = {0022-3816},
  abstract = {Theories of mass politics have stressed the value of partisanship in providing citizens with cues for political decision making. The expanding political skills and resources of contemporary electorates are, however, increasing the abilities of the public and lessening the need for partisan cues. A process of cognitive mobilization in advanced industrial societies is creating a substantial number of apartisans, sophisticated individuals who lack party ties. Data from an eight-nation survey document the correlates of changing mobilization patterns, and link these findings to a new style of dealigned politics.},
