  langid = {english},
  keywords = {Communication in politics -- Great Britain,European Union -- Great Britain,Great Britain -- Politics and government -- 2007-,Twitter -- Political aspects},
  file = {/Users/clemensjarnach/03-UniofOxford/DPhil/06-Library/02-ArchiveLibrary/Simunjak-2022.pdf}
