  langid = {english},
  keywords = {Attitudes,Female,Friendship,Group identity,Human beings,Internet,Logits,Male,Multivariate analysis,Perception,Social groups,Social influence,Social networks,Social perception,Social psychology,Sociometry,Strangers,United States}
}

