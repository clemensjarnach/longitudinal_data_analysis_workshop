@article{fisherDelayedShockHow2023,
  title = {Delayed Shock? {{How Brexit}} Conditioned Campaign Effects in {{British}} General Elections},
  shorttitle = {Delayed Shock?},
  author = {Fisher, Justin and Fieldhouse, Edward and Cutts, David},
  date = {2023-05-30},
