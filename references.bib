  author = {Schroeder, Daniel Thilo and Cha, Meeyoung and Baronchelli, Andrea and Bostrom, Nick and Christakis, Nicholas A. and Garcia, David and Goldenberg, Amit and Kyrychenko, Yara and Leyton-Brown, Kevin and Lutz, Nina and Marcus, Gary and Menczer, Filippo and Pennycook, Gordon and Rand, David G. and Ressa, Maria and Schweitzer, Frank and Song, Dawn and Summerfield, Christopher and Tang, Audrey and Van Bavel, Jay J. and Van Der Linden, Sander and Kunst, Jonas R.},
  date = {2026-01-22},
