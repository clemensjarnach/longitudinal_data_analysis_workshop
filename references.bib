@article{jenningsTiltingCosmopolitanAxis2017,
  title = {Tilting towards the Cosmopolitan Axis? {{Political}} Change in England and the 2017 General Election},
  author = {Jennings, Will and Stoker, Gerry},
  date = {2017},
  journaltitle = {The Political quarterly (London. 1930)},
  volume = {88},
  number = {3},
  pages = {359--369},
  publisher = {Wiley},
  location = {HOBOKEN},
  issn = {0032-3179},
  abstract = {The general election of June 2017 revealed a continued tilting of the political axis in England that has been long in the making. This was not a Brexit ‘realignment’—in that the vote is better seen as a symptom of a longer‐term divide that is emerging between citizens residing in locations strongly connected to global growth and those who are not. In this analysis, we explore constituency‐level patterns of voting in England between 2005 and 2017. Over this period, Labour's vote share has tended to rise in urban areas (that is, major cities), with younger and more diverse and more educated populations often working in ‘cosmopolitan’ industries, whereas the Conservative vote has tended to increase in less densely populated towns and rural areas, with older and less diverse populations. Significantly, Labour has also increased its vote in constituencies with a higher share of ‘precariat’ and emerging service workers—somewhat at odds with characterisation of a party that has lost the ‘left behind’. To the extent that changes in electoral support for the Conservatives and Labour are linked to the Brexit vote, the relationship far predates the referendum vote and should be expected to continue to reshape British politics in future.},
  copyright = {The Authors 2017. The Political Quarterly © The Political Quarterly Publishing Co. Ltd. 2017 Published by John Wiley \& Sons Ltd},
  langid = {english},
  keywords = {2017 general election,Brexit,Cities,Citizens,Conservatism,Constituencies,Constituency,cosmopolitan politics,Elections,EU membership,globalisation,Government & Law,Labor,Political change,Political parties,Political Science,Politics,precariat,Realignment,Referendums,Rural areas,Rural communities,social class,Social Sciences,Towns,Urban areas,Voting},
  file = {/Users/clemensjarnach/03-UniofOxford/DPhil/06-Library/02-ArchiveLibrary/Jennings-Stoker-2017.pdf}
}

